generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String    @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  phone             String?
  role              Role      @default(SENDER)
  stripeAccountId   String?
  stripeCustomerId  String?
  createdAt         DateTime  @default(now())

  jobsPosted        Job[]     @relation("Sender")
  jobsClaimed       Job[]     @relation("Driver")
  ratings           Rating[]  @relation("RatedUser")
  ratingsGiven      Rating[]  @relation("Rater")
  accounts          Account[]
  sessions          Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id              String      @id @default(cuid())
  title           String
  description     String?
  status          JobStatus   @default(OPEN)

  pickupAddress   String
  pickupLat       Float
  pickupLng       Float
  dropoffAddress  String
  dropoffLat      Float
  dropoffLng      Float

  packageSize     PackageSize
  weightKg        Float?
  pricNok         Int

  senderId        String
  sender          User        @relation("Sender", fields: [senderId], references: [id])
  driverId        String?
  driver          User?       @relation("Driver", fields: [driverId], references: [id])

  stripePaymentId String?
  paidAt          DateTime?
  claimedAt       DateTime?
  pickedUpAt      DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime    @default(now())

  tracking        TrackingPoint[]
  rating          Rating?
}

model TrackingPoint {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  lat       Float
  lng       Float
  timestamp DateTime @default(now())
}

model Rating {
  id          String   @id @default(cuid())
  jobId       String   @unique
  job         Job      @relation(fields: [jobId], references: [id])
  raterId     String
  rater       User     @relation("Rater", fields: [raterId], references: [id])
  ratedUserId String
  ratedUser   User     @relation("RatedUser", fields: [ratedUserId], references: [id])
  score       Int
  comment     String?
  createdAt   DateTime @default(now())
}

enum Role {
  SENDER
  DRIVER
  ADMIN
}

enum JobStatus {
  OPEN
  CLAIMED
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum PackageSize {
  SMALL
  MEDIUM
  LARGE
  EXTRA_LARGE
}
